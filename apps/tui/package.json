{
  "name": "@datafoundry/tui",
  "version": "0.2.0",
  "description": "Terminal UI for DataFoundry - CopilotKit protocol client",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "datafoundry-tui": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "datafoundry",
    "tui",
    "copilotkit",
    "terminal",
    "cli"
  ],
  "dependencies": {
    "@ag-ui/core": "^0.0.57",
    "ink": "^7.1.0",
    "ink-table": "^3.1.0",
    "react": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
