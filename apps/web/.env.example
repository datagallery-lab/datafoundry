# DataFoundry Web — formal deploy defaults (password + same-origin BFF).
#
# Native one-click deploy (`./deploy.sh`) generates `apps/web/.env.local` for you.
# It uses same-origin BFF variables (empty NEXT_PUBLIC_* URLs) and sets
# API_PROXY_TARGET from the selected API host/port.
#
# Keep in sync with root `.env` → DATAFOUNDRY_AUTH_MODE.
# NEXT_PUBLIC_* values are baked in at `npm run build:web`.
#
# --- Formal test / real production (default) ---
# Same frontend settings for both; differ in root AUTH_EMAIL_DELIVERY,
# AUTH_PUBLIC_BASE_URL, and AUTH_REGISTRATION_MODE (see root .env.example).
# Registration UI may still follow NEXT_PUBLIC_DATAFOUNDRY_AUTH_MODE until
# M0A.5c reads GET /api/v1/auth/status; API policy is authoritative.
NEXT_PUBLIC_DATAFOUNDRY_AUTH_MODE=password
# Leave empty so the browser uses `/api/v1/*` and `/api/copilotkit` on the
# Next origin (required for session cookies + CSRF).
NEXT_PUBLIC_AGENT_RUNTIME_URL=
NEXT_PUBLIC_CONFIG_API_URL=
API_PROXY_TARGET=http://127.0.0.1:8787
#
# --- Contributor hot-reload only (not formal; do not mix with start:*) ---
# NEXT_PUBLIC_DATAFOUNDRY_AUTH_MODE=dev
# NEXT_PUBLIC_AGENT_RUNTIME_URL=http://127.0.0.1:8787/api/copilotkit
# NEXT_PUBLIC_CONFIG_API_URL=http://127.0.0.1:8787
