# DataFoundry runtime CopilotKit / AG-UI endpoint.
# Password / production builds usually leave this unset so the browser uses the
# same-origin Next BFF at `/api/copilotkit` (required for session cookies).
NEXT_PUBLIC_AGENT_RUNTIME_URL=http://127.0.0.1:8787/api/copilotkit

# Must match root .env DATAFOUNDRY_AUTH_MODE. Frontend reads this at build time
# for production (`next build`) and test deployments.
#   password — show login/register; required for production / formal test.
#   dev      — local-only shortcut; not used for formal test or production.
NEXT_PUBLIC_DATAFOUNDRY_AUTH_MODE=password

# Optional: override REST base. Leave empty in password mode so `/api/v1/*`
# stays same-origin through the Next BFF (cookie + CSRF).
# NEXT_PUBLIC_CONFIG_API_URL=
