@startuml
title General Data Agent - Workspace, Context and Collaboration Architecture

skinparam backgroundColor #F7F5EF
skinparam shadowing false
skinparam roundcorner 10
skinparam defaultFontName Arial
skinparam ArrowColor #263238
skinparam componentBorderColor #263238
skinparam componentBackgroundColor #FFFFFF
skinparam databaseBorderColor #263238
skinparam databaseBackgroundColor #FFF3C4
skinparam packageBorderColor #263238
skinparam packageBackgroundColor #EEF5F2

actor "GUI / TUI" as client

package "Single API Process" {
  component "CopilotKit Runtime\nAG-UI endpoint" as api
  component "Run Identity\nclaim / replay" as identity
  component "Lifecycle Coordinator" as lifecycle
  component "Interaction Runtime\nsuspend / resume" as interaction
  component "Task Activity Projector\nTask state -> AG-UI PLAN" as taskProjector

  package "Per-run Agent Runtime" {
    component "Mastra Agent\nReAct loop" as agent
    component "Context Processors\ncompile + guard" as context
    component "Data Tools" as dataTools
    component "Workspace Tools" as workspaceTools
    component "Builtin Collaboration\ntask_* / ask_user / submit_plan" as builtinTools
    component "Goal Runtime Adapter\nobjective + judge budget" as goal
    component "Tool Observation Router" as router
    component "Context Adapter Registry\none adapter per tool" as adapters
  }

  package "Per-run Workspace" {
    component "LocalFilesystem\nrestricted runDir" as filesystem
    component "Mastra LocalSandbox\nnative isolation detection" as sandbox
    component "Output Manifest\noutputs/ allowlist" as manifest
  }

  component "Data Gateway\nreadonly + audit" as gateway
  component "Artifact Service\ncopy + hash + metadata" as artifacts
  database "Metadata SQLite\nruns / events / audit / artifacts" as metadata
  database "Mastra Thread State\ntasks / memory / objectives" as threadState
  folder "Artifact Storage" as storage
}

client --> api : AG-UI run
api --> identity
identity --> metadata
identity --> agent : trusted run context

agent --> context : every model step
context --> agent : governed prompt
agent --> dataTools
dataTools --> gateway
gateway --> metadata : SQL audit
dataTools --> router : tool observation

agent --> workspaceTools
workspaceTools --> filesystem
workspaceTools --> sandbox
workspaceTools --> router : tool observation
workspaceTools --> manifest : register output

agent --> builtinTools
builtinTools --> threadState : thread-scoped task state
builtinTools --> router : tool observation
router --> adapters : resolve by toolName
adapters --> context : tool-specific ContextItem

builtinTools --> taskProjector : task snapshot
taskProjector --> metadata : persist AG-UI PLAN
taskProjector --> api : ACTIVITY snapshot / delta
builtinTools --> interaction : suspended call
interaction --> metadata : persist request / response
interaction --> api : AG-UI interaction event
api --> interaction : validated resume
interaction --> agent : resumeStream

agent --> goal
goal --> threadState : objective state
goal --> metadata : persisted AG-UI goal events
goal --> api : AG-UI goal event

agent --> lifecycle : generation terminal candidate
lifecycle --> manifest : freeze + validate
lifecycle --> artifacts : archive before RUN_FINISHED
artifacts --> storage
artifacts --> metadata
lifecycle --> metadata : terminal status + AG-UI events
lifecycle --> api : RUN_FINISHED / RUN_ERROR
api --> client : persisted AG-UI stream

note right of sandbox
  Uses @mastra/core/workspace LocalSandbox.
  Command tool is hidden when native
  isolation is unavailable.
end note

note bottom of context
  processInputStep routes every tool result
  to its dedicated ToolObservationAdapter.
  Unknown tools use fail-safe fallback only.
end note

note bottom of taskProjector
  Mastra task state is the source of truth.
  The fixed three-task PLAN is deleted
  after live and replay parity is proven.
end note

note bottom of lifecycle
  Archive first, terminal event second,
  workspace cleanup last.
end note

@enduml
