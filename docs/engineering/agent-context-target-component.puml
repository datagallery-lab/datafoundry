@startuml
title Context Compilation - Phase 4-5 Extension Target

top to bottom direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam backgroundColor #F7F4ED
skinparam defaultFontName Arial
skinparam ArrowColor #30343B

package "Implemented Phase 1-3" #DCE8C9 {
  component "ContextBudgetProcessor" as Processor
  component "Conversation Turn Grouper" as Conversation
  component "ContextRunState" as State
  component "Step Planner" as Planner
  component "Reduction Strategies\n+ Selector" as Reduction
  component "Prompt Token Counter\n+ Model Profiles" as Tokens
  component "Provider Prompt Guard" as Guard
  component "Tool Observation Adapters" as ToolAdapters
}

package "Phase 4 : Memory" #D8EAF1 {
  component "Mastra Memory Adapter" as MemoryAdapter
  component "Recent Messages" as Recent
  component "Session Summary" as Summary
  component "Working Memory" as Working
  database "Memory Store\nresourceId + threadId" as MemoryStore
}

package "Phase 5 : Knowledge" #E7DDF1 {
  component "Knowledge Source Adapter" as KnowledgeAdapter
  component "Retrieval + Rerank" as Retrieval
  component "Citation Groups" as Citations
  database "Collections / Documents / Chunks" as KnowledgeStore
}

package "Shared Context Compiler Contract" #F2D8D5 {
  component "ContextPackage Inventory" as Package
  component "Atomic Context Groups" as Groups
  component "Immutable ContextPlan" as Plan
  component "Transient PromptView" as View
}

Conversation --> Package
ToolAdapters --> Package
MemoryAdapter --> Package
KnowledgeAdapter --> Package

Recent --> MemoryAdapter
Summary --> MemoryAdapter
Working --> MemoryAdapter
MemoryStore --> MemoryAdapter
KnowledgeStore --> Retrieval
Retrieval --> KnowledgeAdapter
Citations --> KnowledgeAdapter

Processor --> State
State --> Package
Package --> Groups
Groups --> Planner
Planner --> Reduction
Planner --> Tokens
Planner --> Plan
Plan --> View
View --> Guard

note right of MemoryAdapter
Memory is a source, not a security boundary.
Client/live/memory history must be deduplicated.
end note

note right of KnowledgeAdapter
Retrieval top-k still competes in the global budget.
Citation and artifact references survive reduction.
end note

@enduml
