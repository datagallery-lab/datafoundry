@startuml
title Context Governance - Current Phase 1-3

top to bottom direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam backgroundColor #F7F4ED
skinparam defaultFontName Arial
skinparam ArrowColor #30343B

actor "AG-UI Client" as Client #F9D65C

package "Ingress" #D8EAF1 {
  component "Protocol Filter\nremove activity / reasoning input" as Filter
  component "Mastra MessageList" as MessageList
}

package "Every ReAct Step" #DCE8C9 {
  component "ContextBudgetProcessor" as Processor #FFFFFF
  component "groupMessagesByTurn\nsingle conversation authority" as Grouper #F9D65C
  component "ContextPackageBuilder" as Builder
  component "ContextRunState\nimmutable revisions" as State
  component "StepContextPlanner" as Planner #FFFFFF
  component "Strategy Registry" as Strategies
  component "Candidate Selector" as Selector
  component "PromptTokenCounter\n+ Model Profiles" as Tokens
}

package "Provider Boundary" #F2D8D5 {
  component "ProviderPromptGuard" as Guard
  cloud "LLM Provider" as Model
}

package "Tool Observation Boundary" #E7DDF1 {
  component "Data Tools" as Tools
  component "ContextOrchestrator" as Orchestrator
  component "Schema / SQL Adapters" as Adapters
  database "Artifact / SQL Audit" as Stores
}

database "run_events\ncontext CUSTOM metrics" as Events #FFFFFF

Client --> Filter : RunAgentInput.messages
Filter --> MessageList
MessageList --> Processor : messages / system / tools
Processor --> Grouper
Grouper --> Builder : atomic turn items
Builder --> State : package revision N
State --> Planner
Planner --> Tokens : count full prompt budget
Planner --> Strategies : collect proposals
Strategies --> Selector
Selector --> Planner : selected reduction
Planner --> Processor : ContextPlan + PromptView
Processor --> MessageList : current-step messages
Processor --> Events : context.compiled

MessageList --> Guard : provider-shaped prompt
Guard --> Tokens : final count
Guard --> Events : context.prompt-verified
Guard --> Model : allow or abort

Model --> Tools : tool call
Tools --> Stores : execute / persist
Tools --> Orchestrator : raw result
Orchestrator --> Adapters
Adapters --> State : observation package
Orchestrator --> MessageList : bounded tool result

note right of Grouper
Only natural user messages start a turn.
The last turn is mandatory and atomic.
end note

note right of Planner
The planner enforces constraints and convergence.
Strategies propose actions; no fixed global order.
end note

@enduml
