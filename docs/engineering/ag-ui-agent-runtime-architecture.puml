@startuml
title Data Agent - Current Runtime

left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam backgroundColor #F7F4ED
skinparam defaultFontName Arial
skinparam ArrowColor #30343B
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #30343B
}

actor "GUI / TUI\nCopilotKit AG-UI" as Client #F9D65C

package "API Surface :8787" #D8EAF1 {
  component "GET /healthz" as Health #FFFFFF
  component "/api/v1/*\nConfig REST" as ConfigRest #FFFFFF
  component "ConfigApiRequest\nresources / jobs / artifacts" as ConfigApi #FFFFFF
  component "POST /api/copilotkit" as Endpoint #FFFFFF
  component "DataAgentAgUiAgent" as Bridge #FFFFFF
  component "Run Identity\nfingerprint / claim / replay" as Identity #F7C9B6
  component "TaskPlanProjector\ndynamic PLAN snapshot" as Plan #F7C9B6
}

package "Mastra Agent Runtime" #DCE8C9 {
  component "@ag-ui/mastra\nMastraAgent" as AgUiMastra
  component "Mastra DataAgent\nReAct + tool calling" as Agent
  component "@ag-ui/mcp-middleware\nenabled MCP servers" as McpMiddleware
  component "MastraContextBudgetProcessor\nevery ReAct step" as ContextProcessor #F9D65C
  component "MastraTaskStateContextProcessor\nthread task snapshot" as TaskProcessor #F9D65C
  component "ProviderPromptGuard\nbefore model call" as PromptGuard #F9D65C
  component "Typed Data Tools\nlist / inspect / preview / SQL" as Tools
  component "Knowledge Tool\nretrieve_knowledge" as KnowledgeTool
  component "Mastra Builtin Task Tools\nwrite / update / complete / check" as TaskTools
  component "Mastra Workspace Tools\nfile ops / isolated command" as WorkspaceTools
}

package "Data Safety Boundary" #F2D8D5 {
  component "MastraToolObservationRouter\nstep-level interception" as ObservationRouter
  component "ToolObservationAdapters\none adapter per tool" as ToolObservationAdapters
  component "LocalDataGateway" as Gateway
  component "LocalKnowledgeService\nFTS + optional embeddings" as Knowledge
  component "Readonly SQL Guard\nlimit / timeout" as SqlGuard
  folder "Session Workspace\nuser / workspace / session" as RunWorkspace
  database "Datasources\nDuckDB / SQLite / CSV / XLSX / PG / MySQL / ClickHouse" as Sources
}

package "Persistence" #E7DDF1 {
  database "Metadata SQLite\nruns / events / config / secrets / jobs" as Metadata
  database "Mastra LibSQL\nthread task state only" as TaskState
  component "run_events\nAG-UI BaseEvent replay" as Events
  component "SQL Audit Logs" as Audit
  component "Artifacts\nmetadata + REST preview/download" as Artifacts
  component "Config Resources\nKB / MCP / model / skill" as ConfigResources
  component "Encrypted Secrets\nSECRET_MASTER_KEY" as Secrets
}

cloud "LLM Provider\nOpenAI-compatible or Mastra router" as Model #D8EAF1

Client --> Endpoint : RunAgentInput
Client --> ConfigRest : workspace config CRUD
Client --> Health
ConfigRest --> ConfigApi
ConfigApi --> Metadata
ConfigApi --> ConfigResources
ConfigApi --> Secrets
ConfigApi --> Gateway : datasource test / introspect
ConfigApi --> Knowledge : KB upload / search / reindex
ConfigApi --> Artifacts : detail / preview / download
Endpoint --> Bridge : route dataAgent
Bridge --> Identity : threadId / runId / parentRunId
Identity --> Metadata : find or atomic claim
Identity --> Events : terminal duplicate replay
Events --> Client : same ordered events

Bridge --> AgUiMastra : new run
AgUiMastra --> Agent
AgUiMastra --> McpMiddleware : use when enabled
McpMiddleware --> Agent : dynamic mcp__ tools
Agent --> ContextProcessor : processInputStep
Agent --> TaskProcessor : processInputStep
TaskProcessor --> TaskState : read thread state
ContextProcessor --> Agent : governed messages
Agent --> PromptGuard : processLLMRequest
PromptGuard --> Model : allow within budget
Model --> Agent : text or tool call

Agent --> Tools
Agent --> KnowledgeTool
Agent --> TaskTools
Agent --> WorkspaceTools
KnowledgeTool --> Knowledge
Knowledge --> Metadata
KnowledgeTool --> ToolObservationAdapters : package observation
Tools --> ToolObservationAdapters : package observation
TaskTools --> TaskState : native threadState mutation
TaskTools --> ObservationRouter : next-step tool result
WorkspaceTools --> ObservationRouter : next-step tool result
ObservationRouter --> ToolObservationAdapters : exact toolName
WorkspaceTools --> RunWorkspace
Tools --> Gateway
Gateway --> SqlGuard
SqlGuard --> Sources
Gateway --> Audit
Gateway --> Artifacts
Audit --> Metadata
Artifacts --> Metadata
ConfigResources --> Metadata
Secrets --> Metadata

Tools --> Bridge : ACTIVITY / CUSTOM
KnowledgeTool --> Bridge : TOOL / CUSTOM references
AgUiMastra --> Bridge : RUN / TEXT / TOOL / REASONING
Bridge --> Plan : project task TOOL_CALL_RESULT
Plan --> Events : append PLAN snapshot
Bridge --> Events : append same BaseEvent
Bridge --> Client : stream same BaseEvent

note bottom of Identity
Terminal duplicate + same fingerprint = replay.
Active duplicate or mismatch = fail closed.
end note

note bottom of Artifacts
Northbound CUSTOM artifact events carry id + summary reference only.
Large preview/content/download flows through /api/v1/artifacts REST.
Model observation keeps artifact_id only.
end note

@enduml
