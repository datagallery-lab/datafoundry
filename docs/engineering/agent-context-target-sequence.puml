@startuml
title Context Compilation - Current Multi-step ReAct Sequence

skinparam shadowing false
skinparam backgroundColor #F7F4ED
skinparam defaultFontName Arial
skinparam sequenceMessageAlign center

actor "CopilotKit / AG-UI" as Client
participant "API Ingress" as Api
participant "Mastra Agent" as Agent
participant "ContextBudgetProcessor" as Processor
participant "Turn Grouper" as Grouper
participant "ContextRunState" as State
participant "Step Planner" as Planner
participant "Strategies + Selector" as Strategies
participant "Provider Prompt Guard" as Guard
participant "Model Provider" as Model
participant "Data Tool" as Tool
participant "Tool Result Adapter" as Adapter
database "Artifact / Audit" as Store
participant "AG-UI Event Sink" as Events

Client -> Api : RunAgentInput(messages)
Api -> Agent : filtered messages

loop Every ReAct step
  Agent -> Processor : processInputStep(messages, system, tools, step)
  Processor -> Grouper : group conversation trajectory
  Grouper --> Processor : atomic turns + mandatory current turn
  Processor -> State : merge live ContextPackage revision
  Processor -> Planner : plan(package, messages, system, tools)
  Planner -> Planner : count global input budget

  alt Prompt exceeds budget
    Planner -> Strategies : collect all proposals
    Strategies --> Planner : selected proposal
    Planner -> Planner : apply decision and re-count
  end

  alt Mandatory set exceeds budget or no progress
    Planner --> Processor : fail closed
    Processor --> Agent : abort run
  else Valid plan
    Planner --> Processor : ContextPlan + PromptView
    Processor -> State : record plan
    Processor -> Events : CUSTOM context.compiled
    Processor --> Agent : current-step messages

    Agent -> Guard : processLLMRequest(provider prompt)
    Guard -> Guard : final prompt count
    Guard -> Events : CUSTOM context.prompt-verified
    alt Final prompt exceeds budget
      Guard --> Agent : abort before provider
    else Final prompt is valid
      Guard --> Agent : allow
      Agent -> Model : prompt + tools
      Model --> Agent : text or tool call
    end
  end

  opt Model calls a data tool
    Agent -> Tool : validated arguments
    Tool -> Store : execute + persist audit/artifact
    Tool -> Adapter : raw result
    Adapter --> Tool : bounded ContextPackage projection
    Tool -> State : register observation package
    Tool --> Agent : model projection + refs
  end
end

Agent --> Client : standard AG-UI event stream

@enduml
